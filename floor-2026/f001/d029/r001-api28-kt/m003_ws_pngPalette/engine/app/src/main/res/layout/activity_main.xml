<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#10141A">

    <!-- ヘッダー: プロジェクト名 / Room / mdID -->
    <TextView
        android:id="@+id/textHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="m003_ws_pngPalette  |  Room r001  |  mdID=0x17"
        android:textColor="#7FDBFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/textStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="server: stopped"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:paddingBottom="8dp" />

    <!-- ログ見出し + クリアボタン -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LOG"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/buttonClearLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear" />
    </LinearLayout>

    <!-- ログ表示テキストボックス(スクロール可能) -->
    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000">

        <TextView
            android:id="@+id/textLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:textColor="#33FF66"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true" />
    </ScrollView>

</LinearLayout>
