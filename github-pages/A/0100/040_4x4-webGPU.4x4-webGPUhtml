<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>WebGPU Canvas Viewer</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: #111;
      display: flex;
      flex-direction: column;
      height: 100dvh;
      overflow: hidden;
      font-family: monospace;
    }

    #info {
      color: #8f8;
      font-size: 11px;
      padding: 4px 8px;
      background: rgba(0,0,0,0.6);
      white-space: nowrap;
      overflow: hidden;
    }

    #gpucanvas {
      /* 短い辺に合わせた正方形・中央寄せ */
      width:  min(100vw, 100dvh);
      height: min(100vw, 100dvh);
      margin: auto;
      display: block;
      touch-action: none;
    }
  </style>
</head>
<body>
  <div id="info">読み込み中...</div>
  <canvas id="gpucanvas"></canvas>

  <script type="module" src="./src/main_webGPU.js"></script>
</body>
</html>
